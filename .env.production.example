NEXT_PUBLIC_APP_NAME=CupMate
NEXT_PUBLIC_APP_URL=https://your-domain.com

NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional authorized HLS live stream for /live and the Watch section.
# Use an HTTPS .m3u8 directly when possible. For an authorized HTTP-only
# upstream on an HTTPS site, set NEXT_PUBLIC_LIVE_HLS_URL=/api/live/playlist
# and put the original upstream in server-only LIVE_HLS_SOURCE_URL.
NEXT_PUBLIC_LIVE_HLS_URL=
NEXT_PUBLIC_LIVE_TITLE=CupMate Live
NEXT_PUBLIC_LIVE_DESCRIPTION=Licensed live coverage appears here when available.
NEXT_PUBLIC_LIVE_POSTER=/assets/cupmate-social-preview-v2.png
NEXT_PUBLIC_LIVE_RIGHTS_NOTE=CupMate is independent. Only authorized live streams should be shown here.
LIVE_HLS_SOURCE_URL=
LIVE_HLS_ALLOWED_HOSTS=

# OBS -> MediaMTX ingest. OBS publishes to:
# Server: rtmp://your-domain.com
# Stream key: cupmate?user=${OBS_STREAM_USER}&pass=${OBS_STREAM_KEY}
RTMP_PORT=1935
OBS_STREAM_USER=cupmate
OBS_STREAM_KEY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

OPENAI_API_KEY=

FOOTBALL_API_KEY=
OPENWEATHER_API_KEY=

# Microsoft Graph delegated email sending.
# Requires an Entra app registration configured as a public client with delegated
# Microsoft Graph permissions: Mail.Send and User.Read.
MICROSOFT_TENANT_ID=
MICROSOFT_CLIENT_ID=
GRAPH_TO=
GRAPH_FROM_ADDRESS=
